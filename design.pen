          ],
          "children": [
            {
              "type": "frame",
              "id": "CGOQv",
              "name": "spArticle",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 32,
              "children": [
                {
                  "type": "text",
                  "id": "49ciu",
                  "fill": "#FFFFFFFF",
                  "textGrowth": "fixed-width",
                  "width": 660,
                  "content": "Introduction",
                  "lineHeight": 1.2,
                  "fontFamily": "Geist",
                  "fontSize": 28,
                  "fontWeight": "700",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "HEhJ9",
                  "fill": "#A1A1AAFF",
                  "textGrowth": "fixed-width",
                  "width": 660,
                  "content": "Flutter's rendering pipeline is one of its most powerful features, yet it remains underexplored by many developers. While widgets like Container, Stack, and ListView cover the vast majority of use cases, sometimes you need a widget that simply doesn't exist — and that's where RenderObject shines.\n\nIn this post, we'll build a custom widget that renders a radial progress indicator with animated segments. Along the way we'll demystify the three-tree architecture (Widget, Element, RenderObject) and show exactly where each piece fits.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "gFcuv",
                  "name": "codeBlock1",
                  "clip": true,
                  "width": "fill_container",
                  "fill": "#0D0D0DFF",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#1A1A1AFF"
                  },
                  "layout": "vertical",
                  "children": [
                    {
                      "type": "frame",
                      "id": "axeO6",
                      "name": "codeBlockHeader",
                      "width": "fill_container",
                      "height": 40,
                      "fill": "#141414FF",
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "#1A1A1AFF"
                      },
                      "padding": [
                        0,
                        16
                      ],
                      "justifyContent": "space_between",
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "text",
                          "id": "iEIJl",
                          "fill": "#A1A1AAFF",
                          "content": "render_object_example.dart",
                          "fontFamily": "Geist Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "pK5fx",
                          "name": "copyBtn",
                          "height": 26,
                          "fill": "#1A1A1AFF",
                          "cornerRadius": 4,
                          "gap": 6,
                          "padding": [
                            0,
                            10
                          ],
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "xUpj7",
                              "width": 12,
                              "height": 12,
                              "iconFontName": "copy",
                              "iconFontFamily": "lucide",
                              "fill": "#A1A1AAFF"
                            },
                            {
                              "type": "text",
                              "id": "jeTTC",
                              "fill": "#A1A1AAFF",
                              "content": "Copy",
                              "fontFamily": "Geist Mono",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "ngO8C",
                      "name": "codeContent",
                      "layout": "vertical",
                      "gap": 4,
                      "padding": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "3lB26",
                          "fill": "#A855F7FF",
                          "content": "class RadialProgressWidget extends LeafRenderObjectWidget {",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "qI8Sp",
                          "fill": "#FFFFFFFF",
                          "content": "  final double progress;",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gfbqK",
                          "fill": "#FFFFFFFF",
                          "content": "  final Color color;",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "9LRd4",
                          "fill": "#A1A1AAFF",
                          "content": " ",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "ix8M1",
                          "fill": "#A1A1AAFF",
                          "content": "  @override",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "Y5hMU",
                          "fill": "#3B82F6FF",
                          "content": "  RenderObject createRenderObject(BuildContext context) {",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "K1Xo1",
                          "fill": "#FFFFFFFF",
                          "content": "    return RenderRadialProgress(progress: progress, color: color);",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "5n9xt",
                          "fill": "#3B82F6FF",
                          "content": "  }",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "1itrn",
                          "fill": "#A855F7FF",
                          "content": "}",
                          "fontFamily": "Geist Mono",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "sjqzp",
                  "fill": "#FFFFFFFF",
                  "textGrowth": "fixed-width",
                  "width": 660,
                  "content": "The Three-Tree Architecture",
                  "lineHeight": 1.2,
                  "fontFamily": "Geist",
                  "fontSize": 28,
                  "fontWeight": "700",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "m09wD",
                  "fill": "#A1A1AAFF",
                  "textGrowth": "fixed-width",
                  "width": 660,
                  "content": "Flutter maintains three parallel trees at all times: the Widget tree (your declarations), the Element tree (the live instances that manage state and lifecycle), and the RenderObject tree (the actual layout and paint nodes). When you create a custom RenderObject, you're working directly in that third tree.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "X1NGq",
                  "name": "infoBox",
                  "width": "fill_container",
                  "fill": "#A855F710",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "#A855F730"
                  },
                  "gap": 16,
                  "padding": 24,
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "EFO8m",
                      "width": 18,
                      "height": 18,
                      "iconFontName": "info",
                      "iconFontFamily": "lucide",
                      "fill": "#A855F7FF"
                    },
                    {
                      "type": "text",
                      "id": "A9DtN",
                      "fill": "#A855F7CC",
                      "textGrowth": "fixed-width",
                      "width": 580,
                      "content": "Pro tip: The performLayout method is called when constraints change. Always call markNeedsPaint() instead of markNeedsLayout() when only visual properties change — it's significantly cheaper.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "t7Bk0",
                  "fill": "#FFFFFFFF",
                  "textGrowth": "fixed-width",
                  "width": 660,
                  "content": "Implementing performLayout",
                  "lineHeight": 1.2,
                  "fontFamily": "Geist",
                  "fontSize": 28,
                  "fontWeight": "700",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "YJOC6",
                  "fill": "#A1A1AAFF",
